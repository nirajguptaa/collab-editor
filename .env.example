# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=collab
POSTGRES_PASSWORD=collab_secret
POSTGRES_DB=collab_editor
DATABASE_URL=postgresql://collab:collab_secret@postgres:5432/collab_editor

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── AI (choose one) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
AI_PROVIDER=anthropic

# ── Frontend ─────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000
